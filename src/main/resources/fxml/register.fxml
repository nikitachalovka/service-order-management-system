<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.example.ordersystem.controller.RegisterController">

  <children>

    <VBox alignment="CENTER"
      spacing="15"
      prefWidth="350"
      styleClass="left-panel">

      <children>
        <Label text="Service Order System"
          styleClass="logo-title"/>

        <Label text="Система управління замовленнями"
          styleClass="logo-subtitle"/>
      </children>

    </VBox>

    <VBox alignment="CENTER"
      spacing="6"
      prefWidth="450"
      styleClass="auth-page">

      <padding>
        <Insets top="25" right="50" bottom="25" left="50"/>
      </padding>

      <children>

        <Label text="Реєстрація"
          styleClass="auth-title"/>

        <TextField fx:id="usernameField"
          promptText="Username"
          styleClass="auth-input"/>
        <Label fx:id="usernameError"
          styleClass="field-error"/>

        <TextField fx:id="emailField"
          promptText="Email"
          styleClass="auth-input"/>
        <Label fx:id="emailError"
          styleClass="field-error"/>

        <PasswordField fx:id="passwordField"
          promptText="Password"
          styleClass="auth-input"/>
        <Label fx:id="passwordError"
          styleClass="field-error"/>

        <HBox spacing="10"
          alignment="CENTER">

          <Button text="Get Code"
            onAction="#handleSendCode"
            styleClass="secondary-button"/>

          <TextField fx:id="codeField"
            promptText="6-digit code"
            styleClass="code-field"/>

        </HBox>

        <Label fx:id="codeError"
          styleClass="field-error"/>

        <Label fx:id="errorLabel"
          styleClass="error-label"/>

        <Button text="Register"
          onAction="#handleRegister"
          styleClass="primary-button"/>

        <Hyperlink text="Вже є акаунт? Увійти"
          onAction="#openLogin"/>

      </children>

    </VBox>

  </children>

</HBox>